{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "ignoreDeprecations": "6.0",
        "strict": true,
        "types": ["vite/client", "node"],
        "noImplicitOverride": true,
        "noUncheckedIndexedAccess": true
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.d.ts",
        "resources/js/**/*.vue",
        "vite.config.ts"
    ],
    "exclude": ["node_modules", "vendor", "public"]
}

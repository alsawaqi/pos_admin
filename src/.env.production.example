# =============================================================================
# pos_admin — PRODUCTION .env template  (posadmin.mithqal.net)
# Copy to `src/.env` on the VPS and fill the secrets (APP_KEY, DB_PASSWORD).
#   cp src/.env.production.example src/.env
# =============================================================================

APP_NAME="MITHQAL POS Admin"
APP_ENV=production
# Generate ONCE, then paste the SAME value into pos_merchant's .env.
# pos_admin encrypts PII (phone, civil_id) on the shared pos_users table with
# this key — a mismatch makes every encrypted read fail "MAC is invalid".
#   docker compose -f docker-compose.prod.yml run --rm artisan php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://posadmin.mithqal.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logs go to stderr -> docker logs (compose also forces LOG_CHANNEL=stderr).
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Sentry (optional) — set the project DSN to enable error reporting in prod.
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# ---- Shared charity Postgres (charity_db) on charity_net --------------------
DB_CONNECTION=pgsql
DB_HOST=chariyt-db
DB_PORT=5432
DB_DATABASE=charity_db
DB_USERNAME=charity_user
DB_PASSWORD=
# pos_admin tracks ITS migrations here, isolated from charity's `migrations`
# table. `migrate --force` is additive; never run migrate:fresh/rollback/wipe.
DB_MIGRATIONS_TABLE=pos_admin_migrations

POS_ADMIN_IDLE_TIMEOUT_MINUTES=30
POS_ADMIN_JWT_TTL_MINUTES=60
POS_ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=5
POS_ADMIN_DEFAULT_NAME="MITHQAL Admin"
POS_ADMIN_DEFAULT_EMAIL=admin@mithqal.net
POS_ADMIN_DEFAULT_PASSWORD=

# ---- Sessions / cache / queue (Redis) --------------------------------------
SESSION_DRIVER=redis
SESSION_COOKIE=pos_admin_web_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Host-only cookie per subdomain — keep null so posadmin + posmerchant don't
# share a session cookie.
SESSION_DOMAIN=null
# We sit behind an HTTPS reverse proxy (trustProxies is on), so issue secure
# cookies only over TLS.
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=pos_admin_cache

REDIS_CLIENT=phpredis
# Matches the unique redis service name in docker-compose.prod.yml.
REDIS_HOST=pos_admin_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@mithqal.net"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Document storage (set S3 creds if you move documents off local disk) ----
DOCUMENTS_DISK_DRIVER=local

# ---- Front-end build (Vite) ------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=https://posadmin.mithqal.net
# Public, referrer-restricted Google Maps key (ships in the JS bundle — lock it
# to posadmin.mithqal.net in the Google Cloud console).
VITE_GOOGLE_MAPS_API_KEY=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Scalefusion (MDM) — set the token for live device data ----------------
SCALEFUSION_TOKEN=
SCALEFUSION_BASE_V3=https://api.scalefusion.com/api/v3
SCALEFUSION_BASE_V1=https://api.scalefusion.com/api/v1

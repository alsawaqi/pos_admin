APP_NAME="MITHQAL POS Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8086

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sentry — leave SENTRY_LARAVEL_DSN empty in local dev to disable.
# Set to the project DSN from sentry.io/settings/<org>/projects/.../keys/
# in staging + production. The Vue side uses VITE_SENTRY_DSN (further down).
# SAMPLE_RATE 1.0 = capture every error; TRACES_SAMPLE_RATE 0.1 = 10% of
# performance traces. Tune lower if quota becomes a concern.
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
# Keep PII off by default — we attach user id + email via our own
# AttachSentryContext middleware so we control what's sent.
SENTRY_SEND_DEFAULT_PII=false

DB_CONNECTION=pgsql
DB_HOST=chariyt-db
DB_PORT=5432
DB_DATABASE=charity_db
DB_USERNAME=charity_user
DB_PASSWORD=super_secret_password
# Migrations tracking stays in its own table so pos_admin can migrate/rollback
# independently of the charity app that owns the rest of this database.
DB_MIGRATIONS_TABLE=pos_admin_migrations

POS_ADMIN_IDLE_TIMEOUT_MINUTES=30
POS_ADMIN_JWT_TTL_MINUTES=60
POS_ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=5
POS_ADMIN_DEFAULT_NAME="MITHQAL Admin"
POS_ADMIN_DEFAULT_EMAIL=admin@mithqal.local
POS_ADMIN_DEFAULT_PASSWORD=MithqalAdmin@2026!

# Session, queue, cache, password_reset_tokens and personal_access_tokens all
# reuse the charity DB's existing default-named tables. We only override the
# session COOKIE name so charity and pos_admin can hold independent sessions
# on the same host. PREFIX is set on the redis/cache key namespace to keep
# our cache entries from colliding with charity's.
SESSION_DRIVER=redis
SESSION_COOKIE=pos_admin_web_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=pos_admin_cache

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# Must match the unique service name in docker-compose.yml. The shared
# charity_net has another project's `redis` service on it, so using the
# generic name would round-robin DNS between two Redis instances and split
# sessions/cache between them.
REDIS_HOST=pos_admin_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

DOCUMENTS_DISK_DRIVER=local
DOCUMENTS_AWS_ACCESS_KEY_ID=
DOCUMENTS_AWS_SECRET_ACCESS_KEY=
DOCUMENTS_AWS_DEFAULT_REGION=us-east-1
DOCUMENTS_AWS_BUCKET=
DOCUMENTS_AWS_URL=
DOCUMENTS_AWS_ENDPOINT=
DOCUMENTS_AWS_USE_PATH_STYLE_ENDPOINT=true
DOCUMENTS_LOCAL_ROOT=

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://localhost:8086
# Vue-side Sentry DSN. Separate from the Laravel one so the two sides
# can route to different Sentry projects if needed (recommended:
# one project per surface so quota / alerts segment cleanly).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_PORT is the bind port INSIDE the container — matches the right-hand side
# of the `vite` service's `5175:5174` mapping in docker-compose. Don't change
# without also updating the compose mapping.
VITE_PORT=5174
# VITE_DEV_SERVER_URL and VITE_HMR_PORT are the HOST-facing values — what your
# browser sees. Must equal the LEFT side of the compose mapping (5175). The
# pos_merchant project sits on host port 5174, so keeping these at 5174 would
# load pos_merchant's Vite into pos_admin pages and break HMR/CSS.
VITE_DEV_SERVER_URL=http://localhost:5175
VITE_DEV_SERVER_CORS_ORIGINS=http://localhost:8086,http://127.0.0.1:8086
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5175

# Scalefusion (MDM) — live device status on the admin devices list.
# SCALEFUSION_TOKEN must be set for live data; the rest have defaults.
SCALEFUSION_TOKEN=
SCALEFUSION_BASE_V3=https://api.scalefusion.com/api/v3
SCALEFUSION_BASE_V1=https://api.scalefusion.com/api/v1
SCALEFUSION_CACHE_STORE=
SCALEFUSION_SUMMARY_TTL=60
SCALEFUSION_STALE_TTL=900
SCALEFUSION_CACHE_LOCK_SECONDS=20
SCALEFUSION_TIMEOUT_SECONDS=8
SCALEFUSION_HTTP_RETRY_ATTEMPTS=3
SCALEFUSION_PER_PAGE=200
SCALEFUSION_MAX_PAGES=25
